{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cloudstream-win",
  "version": "0.1.0",
  "identifier": "com.cloudstream.win",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "devUrl":             "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist":       "../dist"
  },
  "app": {
    "windows": [
      {
        "title":      "CloudStream Win",
        "width":      1200,
        "height":     800,
        "minWidth":   900,
        "minHeight":  600,
        "decorations": true,
        "resizable":  true,
        "center":     true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/cloudstream-bridge.jar",
      "resources/jre/**"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "java",
          "cmd":  "java",
          "args": true,
          "sidecar": false
        },
        {
          "name":    "java-bundled",
          "cmd":     "resources/jre/bin/java.exe",
          "args":    true,
          "sidecar": false
        }
      ]
    }
  }
}
